@{
    Layout = "~/Views/Shared/_ProfileLayout.cshtml";
    ViewData["Title"] = ViewData["Title"] ?? "Profilim - Sorularım";
    ViewData["ProfilePageTitle"] = ViewData["ProfilePageTitle"] ?? "Hesap Sorularım";
    ViewData["ProfilePageDescription"] = ViewData["ProfilePageDescription"] ?? "Oturum açan hesaba ait sorular listelenir.";
    ViewData["ProfileActiveTab"] = ViewData["ProfileActiveTab"] ?? "questions";
}

<div id="questionsLoading" class="text-center py-5">
    <div class="spinner-border text-primary" role="status"></div>
    <p class="text-muted mt-3 mb-0">Sorular yükleniyor...</p>
</div>

<div id="questionsEmpty" class="alert alert-light border d-none mb-0">
    Henüz soru eklenmemiş.
</div>

<div id="questionsList" class="d-grid gap-3"></div>

@section ProfilePageScripts {
    <script>
        function slugify(text) {
            return (text || "")
                .toString()
                .trim()
                .toLowerCase()
                .replace(/[^a-z0-9\u00C0-\u024f\s-]/g, "")
                .replace(/\s+/g, "-")
                .replace(/-+/g, "-");
        }

        window.loadProfilePageData = function (ctx) {
            const $loading = $("#questionsLoading");
            const $empty = $("#questionsEmpty");
            const $list = $("#questionsList");

            function card(q) {
                const created = q.created ? new Date(q.created).toLocaleString("tr-TR") : "-";
                const questionSlug = (q.slug || "").toString().trim();
                const questionUrl = questionSlug ? `/Questions/${encodeURIComponent(questionSlug)}` : "#";

                const tags = Array.isArray(q.tags) && q.tags.length
                    ? q.tags.map(t => {
                        const tagSlug = (t?.slug || "").toString().trim();
                        const tagUrl = tagSlug ? `/Tags/${encodeURIComponent(tagSlug)}` : "#";
                        return `<a href="${tagUrl}" class="badge text-bg-light border me-1 mb-1 text-decoration-none text-dark">#${t?.name || "-"}</a>`;
                    }).join("")
                    : `<span class="text-muted small">Etiket yok</span>`;

                return `
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex flex-wrap gap-2 mb-2">
                                <span class="badge text-bg-secondary">Cevap: ${q.answerCount ?? 0}</span>
                                <span class="badge text-bg-light border text-dark">Görüntülenme: ${q.viewCount ?? 0}</span>
                            </div>
                                
                            <h5 class="fw-bold mb-2">
                                <a href="${questionUrl}" class="text-decoration-none">${q.title || "-"}</a>
                            </h5>
                            <p class="text-muted mb-3">${q.content || ""}</p>

                            <div class="mb-2">${tags}</div>
                            <small class="text-muted">Oluşturulma: ${created}</small>
                        </div>
                    </div>
                `;
            }

            $.ajax({
                url: ctx.isPublicProfile
                    ? (ctx.apiBaseUrl + "/Question/user/" + encodeURIComponent(ctx.profileUserName || ""))
                    : (ctx.apiBaseUrl + "/Question/my"),
                type: "GET",
                headers: (!ctx.isPublicProfile && ctx.token) ? { "Authorization": "Bearer " + ctx.token } : {},
                success: function (res) {
                    const list = Array.isArray(res) ? res : [];
                    $list.empty();

                    if (!list.length) {
                        $empty.removeClass("d-none").text(ctx.isPublicProfile ? "Bu kullanıcının henüz sorusu yok." : "Henüz soru eklenmemiş.");
                        return;
                    }

                    list.forEach(item => $list.append(card(item)));
                },
                error: function () {
                    $empty.removeClass("d-none").text("Sorular alınamadı. Lütfen tekrar deneyin.");
                },
                complete: function () {
                    $loading.addClass("d-none");
                }
            });
        };
    </script>
}