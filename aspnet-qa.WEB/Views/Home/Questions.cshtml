@{
    ViewData["Title"] = "Sorular";
    var apiBaseUrl = ViewBag.ApiBaseURL as string ?? "";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Sorular</h1>
            <p class="text-muted mb-0">Soruları ara ve filtrele.</p>
        </div>
        <span id="questionCount" class="badge rounded-pill text-bg-primary fs-6 px-3 py-2">0 soru</span>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-xl-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input id="txtSearch" type="text" class="form-control" placeholder="Başlık veya içerik ara..." />
                    </div>
                </div>
                <div class="col-12 col-xl-7">
                    <div class="d-flex flex-wrap gap-2 justify-content-xl-end">
                        <button type="button" class="btn btn-primary filter-btn active" data-filter="newest">En yeni</button>
                        <button type="button" class="btn btn-outline-primary filter-btn" data-filter="unanswered">Cevaplanmamış</button>
                        <button type="button" class="btn btn-outline-primary filter-btn" data-filter="myunanswered">Cevaplanmamış (Benim)</button>
                        <button type="button" class="btn btn-outline-primary filter-btn" data-filter="topscore">Skoru yüksek</button>
                        <button type="button" class="btn btn-outline-primary filter-btn" data-filter="popular">Popüler</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="loadingBox" class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="text-muted mt-3 mb-0">Sorular yükleniyor...</p>
    </div>

    <div id="emptyBox" class="alert alert-light border text-center d-none">
        Filtreye uygun soru bulunamadı.
    </div>

    <div id="questionsList" class="d-grid gap-3"></div>
</div>

<style>
    .question-content {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .meta-box {
        min-width: 88px;
    }
</style>

@section Scripts {
    <script>
        $(function () {
            const apiBaseUrl = "@apiBaseUrl";
            const cleanApiBaseUrl = apiBaseUrl.endsWith("/") ? apiBaseUrl.slice(0, -1) : apiBaseUrl;
            const apiOrigin = cleanApiBaseUrl ? new URL(cleanApiBaseUrl).origin : "";
            const defaultPhoto = "/Files/UserPhotos/default-profile-photo.jpg";

            let allQuestions = [];
            let activeFilter = "newest";
            const currentUserId = getCurrentUserId();

            function getCurrentUserId() {
                const token = localStorage.getItem("token");
                if (!token) return null;

                try {
                    const payload = token.split(".")[1].replace(/-/g, "+").replace(/_/g, "/");
                    const json = decodeURIComponent(escape(window.atob(payload)));
                    const obj = JSON.parse(json);

                    return obj["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier"]
                        || obj.nameid
                        || obj.sub
                        || null;
                } catch {
                    return null;
                }
            }

            function toRelativeTime(dateValue) {
                const dt = new Date(dateValue);
                if (Number.isNaN(dt.getTime())) return "Bilinmiyor";

                const sec = Math.floor((Date.now() - dt.getTime()) / 1000);
                if (sec < 60) return "Az önce";

                const min = Math.floor(sec / 60);
                if (min < 60) return `${min} dakika önce`;

                const hour = Math.floor(min / 60);
                if (hour < 24) return `${hour} saat önce`;

                const day = Math.floor(hour / 24);
                if (day < 7) return `${day} gün önce`;

                const week = Math.floor(day / 7);
                if (week < 5) return `${week} hafta önce`;

                const month = Math.floor(day / 30);
                if (month < 12) return `${month} ay önce`;

                const year = Math.floor(day / 365);
                return `${year} yıl önce`;
            }

            function normalizePhoto(photoUrl) {
                const val = (photoUrl || "").trim();
                if (!val) return defaultPhoto;

                if (val.startsWith("http://") || val.startsWith("https://")) return val;
                if (!apiOrigin) return defaultPhoto;

                if (val.startsWith("/Files/")) return apiOrigin + val;
                return apiOrigin + "/Files/UserPhotos/" + val.replace(/^\/+/, "");
            }

            function normalizeQuestion(q) {
                return {
                    id: q.id,
                    title: q.title || "-",
                    content: q.content || "",
                    viewCount: Number(q.viewCount) || 0,
                    score: Number(q.score) || 0,
                    answerCount: Number(q.answerCount) || 0,
                    appUserId: q.appUserId || "",
                    authorName: q.authorName || "Kullanıcı",
                    authorUserName: q.authorUserName || q.authorName || "kullanici",
                    authorPhotoUrl: normalizePhoto(q.authorPhotoUrl),
                    created: q.created,
                    tags: Array.isArray(q.tags) ? q.tags : []
                };
            }

            function sortNewest(a, b) { return new Date(b.created) - new Date(a.created); }
            function sortTopScore(a, b) { return b.score - a.score; }
            function sortPopular(a, b) { return (b.viewCount - a.viewCount && b.score - a.score); }

            function applyFilterAndRender() {
                const search = ($("#txtSearch").val() || "").toString().trim().toLowerCase();

                let data = allQuestions.filter(q =>
                    q.title.toLowerCase().includes(search) ||
                    q.content.toLowerCase().includes(search)
                );

                if (activeFilter === "unanswered") {
                    data = data.filter(q => q.answerCount === 0).sort(sortNewest);
                } else if (activeFilter === "myunanswered") {
                    data = data
                        .filter(q => q.answerCount === 0 && currentUserId && q.appUserId === currentUserId)
                        .sort(sortNewest);
                } else if (activeFilter === "topscore") {
                    data = data.sort(sortTopScore);
                } else if (activeFilter === "popular") {
                    data = data.sort(sortPopular);
                } else {
                    data = data.sort(sortNewest);
                }

                render(data);
            }

            function render(list) {
                const $list = $("#questionsList");
                const $empty = $("#emptyBox");

                $list.empty();

                if (!list.length) {
                    $("#questionCount").text("0 soru");
                    $empty.removeClass("d-none");
                    return;
                }

                $empty.addClass("d-none");
                $("#questionCount").text(`${list.length} soru`);

                list.forEach(q => {
                    const tagsHtml = q.tags.length
                        ? q.tags.map(t => `<span class="badge text-bg-light border me-1 mb-1">#${t.name}</span>`).join("")
                        : `<span class="text-muted small">Etiket yok</span>`;

                    const html = `
                        <div class="card question-card border-0 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex flex-column flex-lg-row gap-3">
                                    <div class="d-flex flex-lg-column gap-2">
                                        <div class="meta-box border rounded-3 p-2 text-center">
                                            <div class="fw-bold">${q.score}</div>
                                            <small class="text-muted">Vote</small>
                                        </div>
                                        <div class="meta-box border rounded-3 p-2 text-center">
                                            <div class="fw-bold">${q.answerCount}</div>
                                            <small class="text-muted">Cevap</small>
                                        </div>
                                        <div class="meta-box border rounded-3 p-2 text-center">
                                            <div class="fw-bold">${q.viewCount}</div>
                                            <small class="text-muted">Görüntüleme</small>
                                        </div>
                                    </div>

                                    <div class="flex-grow-1">
                                        <h5 class="fw-bold mb-2">${q.title}</h5>
                                        <p class="text-muted question-content mb-3">${q.content}</p>

                                        <div class="mb-3">${tagsHtml}</div>

                                        <div class="d-flex align-items-center gap-2">
                                            <img src="${q.authorPhotoUrl}"
                                                 class="rounded-circle border"
                                                 style="width:32px;height:32px;object-fit:cover;"
                                                 onerror="this.onerror=null;this.src='${defaultPhoto}';"
                                                 alt="${q.authorUserName}" />
                                            <div class="small text-muted">
                                                <strong class="text-dark">@@${q.authorUserName}</strong> · ${toRelativeTime(q.created)}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>`;

                    $list.append(html);
                });
            }

            function loadQuestions() {
                $("#loadingBox").removeClass("d-none");
                $("#emptyBox").addClass("d-none");
                $("#questionsList").empty();

                $.ajax({
                    url: cleanApiBaseUrl + "/Question",
                    type: "GET",
                    success: function (res) {
                        allQuestions = (Array.isArray(res) ? res : []).map(normalizeQuestion);
                        applyFilterAndRender();
                    },
                    error: function () {
                        allQuestions = [];
                        render([]);
                        $("#emptyBox").removeClass("d-none").text("Sorular alınamadı. Lütfen tekrar deneyin.");
                    },
                    complete: function () {
                        $("#loadingBox").addClass("d-none");
                    }
                });
            }

            $("#txtSearch").on("input", applyFilterAndRender);

            $(document).on("click", ".filter-btn", function () {
                $(".filter-btn").removeClass("btn-primary active").addClass("btn-outline-primary");
                $(this).removeClass("btn-outline-primary").addClass("btn-primary active");

                activeFilter = $(this).data("filter");
                applyFilterAndRender();
            });

            loadQuestions();
        });
    </script>
}